{
  "manifest_version": 3,
  "name": "Multi Encoder/Decoder",
  "version": "2.0",
  "description": "多機能なエンコード/デコードツール (Unicode, URL, Base64, HTMLなど)",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Multi Encoder/Decoder"
  }
}